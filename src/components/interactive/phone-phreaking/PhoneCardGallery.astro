---
import type { LocaleCode } from '../../../i18n/config';
import { Image } from 'astro:assets';
import cartaoZagatti from '../../../content/blog/phone-phreaking/cartao-zagatti.jpg';
import cartaoColegio from '../../../content/blog/phone-phreaking/cartao-colegio-biotecnico.jpg';
import trilhasCartao from '../../../content/blog/phone-phreaking/trilhas-cartao-indutivo.png';
import cartoes500anos from '../../../content/blog/phone-phreaking/cartoes-telemar-500anos.jpg';
import cartoesAlbum from '../../../content/blog/phone-phreaking/cartoes-album.jpg';
import cartoesSenna from '../../../content/blog/phone-phreaking/cartoes-senna.jpg';

interface Props {
	locale: LocaleCode;
}

const { locale } = Astro.props;

type Card = {
	img: ImageMetadata;
	alt: { pt: string; en: string };
	title: { pt: string; en: string };
	source: string;
};

const cards: Card[] = [
	{
		img: cartaoZagatti,
		alt: {
			pt: 'Cartão telefônico brasileiro Telebras dos anos 90 com estampa colorida',
			en: '1990s Brazilian Telebras phone card with colorful artwork',
		},
		title: { pt: 'Telebras · anos 90', en: 'Telebras · 1990s' },
		source: 'ZAGATTI ARCHIVE',
	},
	{
		img: cartaoColegio,
		alt: {
			pt: 'Cartão telefônico comemorativo do Colégio Biotécnico',
			en: 'Commemorative phone card from Colégio Biotécnico',
		},
		title: { pt: 'Comemorativo · institucional', en: 'Commemorative · institutional' },
		source: 'ARQUIVO PÚBLICO',
	},
	{
		img: trilhasCartao,
		alt: {
			pt: 'Verso de cartão telefônico indutivo mostrando as trilhas e bobinas',
			en: 'Back of an inductive phone card showing the tracks and coils',
		},
		title: { pt: 'Trilhas indutivas · verso', en: 'Inductive tracks · back' },
		source: 'ARQUIVO',
	},
	{
		img: cartoes500anos,
		alt: {
			pt: 'Série Telemar Brasil 500 Anos: 12 cartões formando um mosaico do mapa do Brasil',
			en: 'Telemar Brasil 500 Anos series: 12 cards forming a mosaic of the map of Brazil',
		},
		title: { pt: 'Série Telemar · Brasil 500 Anos', en: 'Telemar series · Brasil 500 Anos' },
		source: 'COLEÇÃO PESSOAL',
	},
	{
		img: cartoesAlbum,
		alt: {
			pt: 'Álbum de colecionador com diversas séries: telefones antigos, paisagens, personagens',
			en: 'Collector album with various series: vintage phones, landscapes, cartoon characters',
		},
		title: { pt: 'Álbum de colecionador', en: 'Collector album' },
		source: 'COLEÇÃO PESSOAL',
	},
	{
		img: cartoesSenna,
		alt: {
			pt: 'Coleção Sistema Telebrás dedicada a Ayrton Senna, com cartões temáticos da carreira',
			en: 'Sistema Telebrás collection dedicated to Ayrton Senna, with career-themed cards',
		},
		title: { pt: 'Série Senninha · Ayrton Senna', en: 'Senninha series · Ayrton Senna' },
		source: 'COLEÇÃO PESSOAL',
	},
];

const labels = {
	pt: { title: 'PHONE_CARDS.exe', count: 'cartões' },
	en: { title: 'PHONE_CARDS.exe', count: 'cards' },
}[locale];
---

<section class="ph-gallery">
	<div class="ph-gallery-head">
		<span>{labels.title}</span>
		<span class="ph-gallery-count">{cards.length} {labels.count}</span>
	</div>

	<div class="ph-gallery-grid is-cards">
		{cards.map((c) => (
			<figure class="ph-gallery-item">
				<button
					type="button"
					class="ph-gallery-trigger"
					data-lightbox-trigger
					data-fullsrc={c.img.src}
					data-alt={c.alt[locale]}
					data-caption={`${c.title[locale]} · ${c.source}`}
					aria-label={`${locale === 'pt' ? 'Ampliar' : 'Enlarge'}: ${c.title[locale]}`}
				>
					<Image src={c.img} alt={c.alt[locale]} widths={[280, 560]} sizes="(max-width: 600px) 45vw, 240px" class="ph-gallery-img" />
				</button>
				<figcaption class="ph-gallery-cap">
					<span class="ph-gallery-name">{c.title[locale]}</span>
					<span class="ph-gallery-source">{c.source}</span>
				</figcaption>
			</figure>
		))}
	</div>
</section>
