---
import type { LocaleCode } from '../../../i18n/config';

interface Props {
	locale: LocaleCode;
}

const { locale } = Astro.props;
const id = `ph-rotary-${Math.random().toString(36).slice(2, 9)}`;

const strings = {
	pt: {
		title: 'ROTARY_DIAL_v1.0',
		statusIdle: '○ PRONTO',
		statusBusy: '● DISCANDO',
		labelHeader: 'DISCO + CAME → PULSO',
		labelCentral: 'CENTRAL',
		pulses: 'PULSOS',
		hint: 'clique em um dígito',
		legend: 'O disco e a came giram juntos no mesmo eixo. Ao soltar, a came volta e cada dente empurra a paleta de cobre, gerando um pulso elétrico para a central.',
	},
	en: {
		title: 'ROTARY_DIAL_v1.0',
		statusIdle: '○ READY',
		statusBusy: '● DIALING',
		labelHeader: 'DIAL + CAM → PULSE',
		labelCentral: 'SWITCH',
		pulses: 'PULSES',
		hint: 'click a digit',
		legend: 'The disk and the cam spin together on the same shaft. On release, the cam returns and each tooth strikes the copper pawl, generating one electrical pulse to the switch.',
	},
}[locale];

const digits = [
	{ d: '1', a: -60 },
	{ d: '2', a: -90 },
	{ d: '3', a: -120 },
	{ d: '4', a: -150 },
	{ d: '5', a: 180 },
	{ d: '6', a: 150 },
	{ d: '7', a: 120 },
	{ d: '8', a: 90 },
	{ d: '9', a: 60 },
	{ d: '0', a: 30 },
];

// Cam tooth geometry (10 teeth, base inside the dial hub, tip pointing outward)
const camBase = 22;
const camTip = 34;
const halfArc = (2 * Math.PI / 10) / 4;
const camTeeth = Array.from({ length: 10 }).map((_, i) => {
	const a = (i * 36 - 90) * (Math.PI / 180);
	const a1 = a - halfArc;
	const a2 = a + halfArc;
	return `${Math.cos(a1) * camBase},${Math.sin(a1) * camBase} ${Math.cos(a) * camTip},${Math.sin(a) * camTip} ${Math.cos(a2) * camBase},${Math.sin(a2) * camBase}`;
});
---

<div class="ph-rotary" data-ph-rotary-id={id}>
	<div class="ph-rotary-head">
		<span>{strings.title}</span>
		<span class="ph-rotary-status" data-ph-rotary-status>{strings.statusIdle}</span>
	</div>

	<div class="ph-rotary-svg-wrap">
		<svg viewBox="0 0 320 260" xmlns="http://www.w3.org/2000/svg" class="ph-rotary-svg">
			<defs>
				<filter id={`glow-${id}`}>
					<feGaussianBlur stdDeviation="1.4" result="b" />
					<feMerge>
						<feMergeNode in="b" />
						<feMergeNode in="SourceGraphic" />
					</feMerge>
				</filter>
			</defs>

			<text x="14" y="16" class="ph-rotary-svg-label">▸ {strings.labelHeader}</text>
			<text x="306" y="16" text-anchor="end" class="ph-rotary-svg-label-sm">
				{strings.pulses} <tspan data-ph-rotary-pulse-count fill="#7fff7f" font-weight="700">0</tspan>
			</text>

			<g transform="translate(160, 138)">
				<!-- Static outer rim -->
				<circle cx="0" cy="0" r="92" fill="rgba(127,255,127,0.04)" stroke="#7fff7f" stroke-width="1.2" />

				<!-- Static finger stop -->
				<g transform="rotate(60)">
					<rect x="84" y="-7" width="16" height="14" rx="2" fill="#ff6a3d" opacity="0.9" />
				</g>

				<!-- Rotating dial + cam (single rigid body) -->
				<g class="ph-rotary-disk" data-ph-rotary-disk transform="rotate(0)">
					<!-- Translucent dial face -->
					<circle cx="0" cy="0" r="78" fill="rgba(127,255,127,0.06)" stroke="#7fff7f" stroke-width="0.8" />

					<!-- Numbered finger holes -->
					{digits.map(({ d, a }) => {
						const r = 60;
						const x = Math.cos((a * Math.PI) / 180) * r;
						const y = Math.sin((a * Math.PI) / 180) * r;
						return (
							<g>
								<circle cx={x} cy={y} r="9" fill="#020a02" stroke="#7fff7f" stroke-width="1" />
								<text x={x} y={y + 3.2} text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#7fff7f" font-weight="600">{d}</text>
							</g>
						);
					})}

					<!-- Cam wheel (visible inside the dial center) -->
					<circle cx="0" cy="0" r={camBase} fill="rgba(255,106,61,0.18)" stroke="#ff6a3d" stroke-width="1.2" />
					{camTeeth.map((p) => <polygon points={p} fill="#ff6a3d" />)}
					<circle cx="0" cy="0" r="4" fill="#ff6a3d" />
				</g>

				<!-- Pawl pivot (static, just outside cam on the left) -->
				<circle cx="-66" cy="0" r="3" fill="#cd7f32" />

				<!-- Pawl arm (animated rotation around pivot) -->
				<g class="ph-rotary-pawl" data-ph-rotary-pawl transform="rotate(0)" style="transform-origin: -66px 0;">
					<rect x="-66" y="-2" width="32" height="4" rx="1.5" fill="#cd7f32" filter={`url(#glow-${id})`} />
					<circle cx="-66" cy="0" r="3.5" fill="#cd7f32" />
					<circle cx="-34" cy="0" r="3.5" fill="#ffd75a" />
				</g>

				<!-- Electrical wire from pawl pivot up to LED -->
				<path d="M -66,0 Q -86,0 -86,-30 L -86,-58" stroke="#7fff7f" stroke-width="1" fill="none" opacity="0.7" />

				<!-- LED (central indicator) -->
				<circle cx="-86" cy="-66" r="7" class="ph-rotary-led" data-ph-rotary-led fill="#0a1a0a" stroke="#7fff7f" stroke-width="1.3" />
				<text x="-86" y="-80" text-anchor="middle" class="ph-rotary-svg-tag-sm">{strings.labelCentral}</text>
			</g>
		</svg>
	</div>

	<div class="ph-rotary-keys">
		{['1','2','3','4','5','6','7','8','9','0'].map((d) => (
			<button class="ph-rotary-key" data-ph-rotary-key data-digit={d}>{d}</button>
		))}
	</div>

	<div class="ph-rotary-hint">{strings.hint}</div>
	<div class="ph-rotary-legend">{strings.legend}</div>
</div>

<script define:vars={{ id, S: strings }}>
	(() => {
		const root = document.querySelector(`[data-ph-rotary-id="${id}"]`);
		if (!root) return;

		const disk = root.querySelector('[data-ph-rotary-disk]');
		const pawl = root.querySelector('[data-ph-rotary-pawl]');
		const led = root.querySelector('[data-ph-rotary-led]');
		const status = root.querySelector('[data-ph-rotary-status]');
		const pulseCount = root.querySelector('[data-ph-rotary-pulse-count]');
		const keys = root.querySelectorAll('[data-ph-rotary-key]');

		let busy = false;
		let audioCtx = null;

		const click = () => {
			if (!audioCtx) {
				audioCtx = new (window.AudioContext || window.webkitAudioContext)();
			}
			if (audioCtx.state === 'suspended') audioCtx.resume();
			const t = audioCtx.currentTime;
			const osc = audioCtx.createOscillator();
			const gain = audioCtx.createGain();
			osc.type = 'square';
			osc.frequency.value = 220;
			gain.gain.setValueAtTime(0, t);
			gain.gain.linearRampToValueAtTime(0.1, t + 0.002);
			gain.gain.exponentialRampToValueAtTime(0.001, t + 0.05);
			osc.connect(gain).connect(audioCtx.destination);
			osc.start(t);
			osc.stop(t + 0.06);
		};

		const setRot = (el, deg) => el.setAttribute('transform', `rotate(${deg})`);
		const setPawlRot = (deg) => pawl.setAttribute('transform', `rotate(${deg}, -66, 0)`);

		const animate = (apply, from, to, durationMs) =>
			new Promise((resolve) => {
				const start = performance.now();
				const step = (now) => {
					const t = Math.min(1, (now - start) / durationMs);
					const k = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
					apply(from + (to - from) * k);
					if (t < 1) requestAnimationFrame(step);
					else resolve();
				};
				requestAnimationFrame(step);
			});

		const flashLed = () => {
			led.setAttribute('fill', '#ffd75a');
			led.setAttribute('stroke', '#ffd75a');
			setTimeout(() => {
				led.setAttribute('fill', '#0a1a0a');
				led.setAttribute('stroke', '#7fff7f');
			}, 90);
		};

		const dial = async (digit) => {
			if (busy) return;
			busy = true;
			const pulses = digit === '0' ? 10 : Number(digit);
			status.textContent = `${S.statusBusy} ${digit}`;
			status.classList.add('is-busy');

			// Reset the per-digit pulse counter
			let count = 0;
			pulseCount.textContent = '0';

			const turnAngle = pulses * 36;

			// Forward rotation: dial + cam spin together (no pulses, pawl stays put)
			await animate((v) => setRot(disk, v), 0, turnAngle, 280 + pulses * 25);
			await new Promise((r) => setTimeout(r, 160));

			// Return rotation: dial + cam rotate back counterclockwise.
			// The pawl tip (at left of cam) is pushed DOWN by each tooth as it sweeps past,
			// then snaps back up. Each snap = one pulse to the switch.
			const stepDur = 220;
			for (let i = 0; i < pulses; i++) {
				const fromAngle = turnAngle - i * 36;
				const toAngle = fromAngle - 36;
				const diskPromise = animate((v) => setRot(disk, v), fromAngle, toAngle, stepDur);
				setTimeout(() => animate(setPawlRot, 0, 18, stepDur / 2), 0);
				setTimeout(() => animate(setPawlRot, 18, 0, stepDur / 2), stepDur / 2);
				setTimeout(() => {
					flashLed();
					click();
					count++;
					pulseCount.textContent = String(count);
				}, stepDur);
				await diskPromise;
			}

			status.textContent = S.statusIdle;
			status.classList.remove('is-busy');
			busy = false;
		};

		keys.forEach((b) => b.addEventListener('click', () => dial(b.dataset.digit)));

		document.addEventListener('astro:before-swap', () => {
			if (audioCtx) audioCtx.close();
		}, { once: true });
	})();
</script>
