---
import type { LocaleCode } from '../../../i18n/config';
import { Image } from 'astro:assets';
import boxBluePhoto from '../../../content/blog/phone-phreaking/box-blue.jpg';
import boxBlackPhoto from '../../../content/blog/phone-phreaking/box-black.jpg';
import boxBeigePhoto from '../../../content/blog/phone-phreaking/box-beige.jpg';
import boxRedPhoto from '../../../content/blog/phone-phreaking/box-red.jpg';

interface Props {
	locale: LocaleCode;
}

const { locale } = Astro.props;

type BoxKey = 'blue' | 'red' | 'black' | 'beige';

const boxes: Array<{
	key: BoxKey;
	color: string;
	name: { pt: string; en: string };
}> = [
	{ key: 'blue', color: '#3da5ff', name: { pt: 'Blue Box', en: 'Blue Box' } },
	{ key: 'red', color: '#ff4d4d', name: { pt: 'Red Box', en: 'Red Box' } },
	{ key: 'black', color: '#cfd2dd', name: { pt: 'Black Box', en: 'Black Box' } },
	{ key: 'beige', color: '#d8b886', name: { pt: 'Beige Box', en: 'Beige Box' } },
];

const labels = {
	pt: { title: 'BOX_GALLERY.exe' },
	en: { title: 'BOX_GALLERY.exe' },
}[locale];

type PhotoMeta = {
	img: ImageMetadata;
	alt: { pt: string; en: string };
	source: string;
};

const photos: Record<BoxKey, PhotoMeta> = {
	blue: {
		img: boxBluePhoto,
		alt: {
			pt: 'Blue Box construída por Steve Wozniak, exibida no Powerhouse Museum',
			en: 'Blue Box built by Steve Wozniak, on display at the Powerhouse Museum',
		},
		source: 'POWERHOUSE MUSEUM // CC',
	},
	red: {
		img: boxRedPhoto,
		alt: {
			pt: 'Red Box: Radio Shack Memory Pocket Tone Dialer, modificado para emular sinais de moeda',
			en: 'Red Box: Radio Shack Memory Pocket Tone Dialer, modified to emulate coin signals',
		},
		source: 'RADIO SHACK · TONE DIALER',
	},
	black: {
		img: boxBlackPhoto,
		alt: {
			pt: 'Black Box exibida no Telephone Museum, Waltham, MA',
			en: 'Black Box on display at the Telephone Museum, Waltham, MA',
		},
		source: 'TELEPHONE MUSEUM // CC',
	},
	beige: {
		img: boxBeigePhoto,
		alt: {
			pt: 'Beige Box caseira: handset com clipes jacaré',
			en: 'Homemade Beige Box: handset with alligator clips',
		},
		source: 'WIKIMEDIA COMMONS // CC',
	},
};
---

<section class="ph-gallery">
	<div class="ph-gallery-head">
		<span>{labels.title}</span>
		<span class="ph-gallery-count">{boxes.length} {locale === 'pt' ? 'caixas' : 'boxes'}</span>
	</div>

	<div class="ph-gallery-grid">
		{boxes.map((box) => {
			const photo = photos[box.key];
			return (
				<figure class="ph-gallery-item" style={`--box-color: ${box.color}`}>
					<button
						type="button"
						class="ph-gallery-trigger"
						data-lightbox-trigger
						data-fullsrc={photo.img.src}
						data-alt={photo.alt[locale]}
						data-caption={`${box.name[locale]} · ${photo.source}`}
						aria-label={`${locale === 'pt' ? 'Ampliar' : 'Enlarge'}: ${box.name[locale]}`}
					>
						<Image src={photo.img} alt={photo.alt[locale]} widths={[280, 560]} sizes="(max-width: 600px) 45vw, 240px" class="ph-gallery-img" />
					</button>
					<figcaption class="ph-gallery-cap">
						<span class="ph-gallery-name">{box.name[locale]}</span>
						<span class="ph-gallery-source">{photo.source}</span>
					</figcaption>
				</figure>
			);
		})}
	</div>
</section>
