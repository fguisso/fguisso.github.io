---
---

<div class="hero-canvas" aria-hidden="true">
	<canvas id="heroCanvas" aria-hidden="true"></canvas>
</div>

<style>
	.hero-canvas {
		display: none;
		position: relative;
		width: min(420px, 100%);
		aspect-ratio: 1;
		border-radius: var(--border-radius);
		overflow: hidden;
		cursor: auto;
		background: transparent;
	}

	#heroCanvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 2;
	}

	@media (min-width: 980px) {
		.hero-canvas {
			display: block;
		}
	}
</style>

<script type="module">
	import { gsap } from 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/index.js';
	import * as THREE from 'https://unpkg.com/three@0.160.1/build/three.module.js';

	if (typeof window === 'undefined') {
		throw new Error('Window not available');
	}

	const canvas = document.getElementById('heroCanvas');
	if (!canvas) {
		throw new Error('Canvas not found');
	}

	const renderer = new THREE.WebGLRenderer({
		canvas,
		antialias: true,
		alpha: true,
	});
	const pixelRatio = Math.min(window.devicePixelRatio, 2);
	renderer.setSize(canvas.clientWidth, canvas.clientHeight);
	renderer.setPixelRatio(pixelRatio);
	renderer.setClearColor(0x000000, 0);

	const createMetalTexture = () => {
		const textureCanvas = document.createElement('canvas');
		textureCanvas.width = textureCanvas.height = 256;
		const ctx = textureCanvas.getContext('2d');

		const gradient = ctx.createLinearGradient(0, 0, textureCanvas.width, textureCanvas.height);
		gradient.addColorStop(0, 'rgba(255, 255, 255, 0.95)');
		gradient.addColorStop(0.45, 'rgba(200, 210, 255, 0.6)');
		gradient.addColorStop(0.55, 'rgba(120, 180, 255, 0.35)');
		gradient.addColorStop(1, 'rgba(255, 255, 255, 0.9)');
		ctx.fillStyle = gradient;
		ctx.fillRect(0, 0, textureCanvas.width, textureCanvas.height);

		const imageData = ctx.getImageData(0, 0, textureCanvas.width, textureCanvas.height);
		for (let i = 0; i < imageData.data.length; i += 4) {
			const noise = (Math.random() - 0.5) * 10;
			imageData.data[i] += noise;
			imageData.data[i + 1] += noise;
			imageData.data[i + 2] += noise;
		}
		ctx.putImageData(imageData, 0, 0);

		const texture = new THREE.CanvasTexture(textureCanvas);
		texture.wrapS = texture.wrapT = THREE.MirroredRepeatWrapping;
		texture.repeat.set(2, 2);
		texture.anisotropy = renderer.capabilities.getMaxAnisotropy?.() ?? 4;
		return texture;
	};

	const metalTexture = createMetalTexture();

	const scene = new THREE.Scene();
	const camera = new THREE.PerspectiveCamera(45, canvas.clientWidth / canvas.clientHeight, 0.1, 100);
	camera.position.z = 5;

	const group = new THREE.Group();
	scene.add(group);

	// reflective environment so the metal surfaces have something to reflect:
	// without this, metalness ~1 + low roughness just renders as flat black and
	// the per-face roughness patterns are invisible.
	const buildEnvironment = () => {
		const c = document.createElement('canvas');
		c.width = 1024;
		c.height = 512;
		const ctx = c.getContext('2d');
		// lighter base "sky" so the black metal always reflects something and never
		// sinks into the dark page background
		ctx.fillStyle = '#222230';
		ctx.fillRect(0, 0, c.width, c.height);
		const glow = (x, y, r, color) => {
			const g = ctx.createRadialGradient(x, y, 0, x, y, r);
			g.addColorStop(0, color);
			g.addColorStop(1, 'rgba(0,0,0,0)');
			ctx.fillStyle = g;
			ctx.fillRect(0, 0, c.width, c.height);
		};
		glow(220, 170, 320, 'rgba(0,255,127,0.85)'); // accent green
		glow(720, 140, 340, 'rgba(154,26,255,0.8)'); // secondary purple
		glow(500, 410, 380, 'rgba(110,110,255,0.8)'); // highlight blue
		glow(900, 350, 260, 'rgba(255,255,255,0.6)'); // white spec
		glow(60, 430, 240, 'rgba(255,255,255,0.5)');
		glow(500, 90, 300, 'rgba(200,210,255,0.45)'); // top fill
		const equirect = new THREE.CanvasTexture(c);
		equirect.mapping = THREE.EquirectangularReflectionMapping;
		equirect.colorSpace = THREE.SRGBColorSpace;
		const pmrem = new THREE.PMREMGenerator(renderer);
		const env = pmrem.fromEquirectangular(equirect).texture;
		equirect.dispose();
		pmrem.dispose();
		return env;
	};
	scene.environment = buildEnvironment();

	const accentColor = new THREE.Color('#00FF7F');
	const secondaryColor = new THREE.Color('#9A1AFF');
	const highlightColor = new THREE.Color('#6E6EFF');
	const whiteColor = new THREE.Color('#fefefe');
	const darkColor = new THREE.Color('#0e0e16');
	const blendColor = new THREE.Color();
	const emissiveColor = new THREE.Color();

	const material = new THREE.MeshStandardMaterial({
		color: 0x0e0e16,
		metalness: 1.0,
		roughness: 0.18,
		roughnessMap: metalTexture,
		envMapIntensity: 1.7,
		emissive: 0x000000,
		emissiveIntensity: 0.0,
		transparent: true,
		opacity: 0.84,
	});

	const ring = new THREE.Mesh(new THREE.TorusGeometry(2.1, 0.18, 48, 140), material);
	group.add(ring);

	const pyramidGroup = new THREE.Group();
	pyramidGroup.scale.set(0.8, 0.8, 0.8);
	group.add(pyramidGroup);

	// ----- Rubik's pyramid (Pyraminx) -----
	const TET_SCALE = 1.45;
	const SUBDIV = 2; // tiles per edge -> SUBDIV^2 tiles per face (2 = classic Rubik's Pyramid)

	// regular tetrahedron, apex up, centered at origin (circumradius = TET_SCALE)
	const tetVerts = [
		new THREE.Vector3(0, 1, 0),
		new THREE.Vector3(Math.sqrt(8 / 9), -1 / 3, 0),
		new THREE.Vector3(-Math.sqrt(2 / 9), -1 / 3, Math.sqrt(2 / 3)),
		new THREE.Vector3(-Math.sqrt(2 / 9), -1 / 3, -Math.sqrt(2 / 3)),
	].map((v) => v.multiplyScalar(TET_SCALE));

	// all four faces are black; each gets a distinct finish/pattern instead of a color
	const tetFaces = [
		{ idx: [0, 1, 2] },
		{ idx: [0, 2, 3] },
		{ idx: [0, 3, 1] },
		{ idx: [1, 3, 2] }, // base
	];

	const tetCentroid = new THREE.Vector3();
	tetVerts.forEach((v) => tetCentroid.add(v));
	tetCentroid.multiplyScalar(0.25);

	// order a triangle so its geometric normal points away from the centroid (outward)
	const orientOutward = (a, b, c) => {
		const normal = new THREE.Vector3()
			.subVectors(b, a)
			.cross(new THREE.Vector3().subVectors(c, a));
		const dir = new THREE.Vector3().subVectors(a, tetCentroid);
		return normal.dot(dir) < 0 ? [a, c, b] : [a, b, c];
	};

	const triPositions = (a, b, c) => [a.x, a.y, a.z, b.x, b.y, b.z, c.x, c.y, c.z];

	// --- procedural grayscale patterns (used as roughness maps) ---
	const makePattern = (draw) => {
		const c = document.createElement('canvas');
		c.width = c.height = 256;
		const ctx = c.getContext('2d');
		draw(ctx, 256);
		const tex = new THREE.CanvasTexture(c);
		tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
		tex.anisotropy = renderer.capabilities.getMaxAnisotropy?.() ?? 4;
		return tex;
	};

	// carbon-fiber weave: alternating diagonal-shaded cells
	const weavePattern = makePattern((ctx, s) => {
		ctx.fillStyle = '#1a1a1a';
		ctx.fillRect(0, 0, s, s);
		const n = 8;
		const cell = s / n;
		for (let yy = 0; yy < n; yy++) {
			for (let xx = 0; xx < n; xx++) {
				const x = xx * cell;
				const y = yy * cell;
				const flip = (xx + yy) % 2 === 0;
				const g = ctx.createLinearGradient(x, y, flip ? x + cell : x, flip ? y : y + cell);
				g.addColorStop(0, '#dcdcdc');
				g.addColorStop(0.5, '#2a2a2a');
				g.addColorStop(1, '#dcdcdc');
				ctx.fillStyle = g;
				ctx.fillRect(x, y, cell, cell);
			}
		}
	});

	// honeycomb / dot grid
	const dotPattern = makePattern((ctx, s) => {
		ctx.fillStyle = '#cfcfcf';
		ctx.fillRect(0, 0, s, s);
		const n = 6;
		const step = s / n;
		ctx.fillStyle = '#171717';
		for (let yy = 0; yy < n; yy++) {
			for (let xx = 0; xx < n; xx++) {
				const cx = xx * step + step / 2 + (yy % 2 ? step / 2 : 0);
				const cy = yy * step + step / 2;
				ctx.beginPath();
				ctx.arc(cx, cy, step * 0.32, 0, Math.PI * 2);
				ctx.fill();
			}
		}
	});

	// brushed-metal diagonal streaks
	const brushedPattern = makePattern((ctx, s) => {
		ctx.fillStyle = '#202020';
		ctx.fillRect(0, 0, s, s);
		ctx.save();
		ctx.translate(s / 2, s / 2);
		ctx.rotate(Math.PI / 4);
		ctx.translate(-s, -s);
		for (let i = 0; i < 220; i++) {
			const x = (i / 220) * (s * 2);
			const shade = 90 + ((i * 53) % 110);
			ctx.strokeStyle = `rgb(${shade},${shade},${shade})`;
			ctx.lineWidth = 0.8 + ((i * 7) % 3) * 0.6;
			ctx.beginPath();
			ctx.moveTo(x, 0);
			ctx.lineTo(x, s * 2);
			ctx.stroke();
		}
		ctx.restore();
	});

	// faint speckle for the polished mirror face (mostly smooth)
	const speckPattern = makePattern((ctx, s) => {
		ctx.fillStyle = '#080808';
		ctx.fillRect(0, 0, s, s);
		const img = ctx.getImageData(0, 0, s, s);
		for (let i = 0; i < img.data.length; i += 4) {
			const n = Math.random() < 0.04 ? 60 + Math.random() * 80 : 8;
			img.data[i] = img.data[i + 1] = img.data[i + 2] = n;
		}
		ctx.putImageData(img, 0, 0);
	});

	const BLACK = 0x17171e; // very dark grey (reads black) but catches light so it never vanishes
	const faceMaterials = [
		// polished mirror black
		new THREE.MeshStandardMaterial({
			color: BLACK,
			emissive: 0x0d0d16,
			emissiveIntensity: 0.6,
			metalness: 1.0,
			roughness: 0.06,
			roughnessMap: speckPattern,
			envMapIntensity: 2.2,
			side: THREE.DoubleSide,
		}),
		// carbon-fiber weave
		new THREE.MeshStandardMaterial({
			color: BLACK,
			emissive: 0x0d0d16,
			emissiveIntensity: 0.6,
			metalness: 0.6,
			roughness: 0.85,
			roughnessMap: weavePattern,
			envMapIntensity: 1.6,
			side: THREE.DoubleSide,
		}),
		// honeycomb dots
		new THREE.MeshStandardMaterial({
			color: BLACK,
			emissive: 0x0d0d16,
			emissiveIntensity: 0.6,
			metalness: 0.8,
			roughness: 0.8,
			roughnessMap: dotPattern,
			envMapIntensity: 1.8,
			side: THREE.DoubleSide,
		}),
		// brushed metal
		new THREE.MeshStandardMaterial({
			color: BLACK,
			emissive: 0x0d0d16,
			emissiveIntensity: 0.6,
			metalness: 0.95,
			roughness: 0.75,
			roughnessMap: brushedPattern,
			envMapIntensity: 1.9,
			side: THREE.DoubleSide,
		}),
	];

	// black matte plastic for the bevel/sides/back of each chip (the "grout").
	// kept opaque so every chip has a solid depth-writing body: this prevents the
	// alpha-sorting glitches (chips vanishing / showing through each other).
	const shellMaterial = new THREE.MeshStandardMaterial({
		color: 0x010101,
		metalness: 0.2,
		roughness: 0.95,
		side: THREE.DoubleSide,
	});

	// each tile is a solid chip (colored front + beveled black sides/back) so it
	// moves entirely with its piece: no static body is left behind during a turn
	const TILE_SHRINK = 0.86;
	const TILE_LIFT = 0.02 * TET_SCALE;
	const TILE_BACK_SCALE = 0.32; // back face pulled in toward the centroid (wedge -> fills the body)
	const TILE_BEVEL_DEPTH = 0.03 * TET_SCALE; // small rounded-ish edge
	const TILE_BEVEL_INSET = 0.16; // how far the bevel pulls in toward the tile center
	const UV_SCALE = 0.6; // pattern repeats per world unit across a face

	// every tile lives directly in pyramidGroup with its geometry in absolute
	// (centroid-origin) coords and mesh.position = 0, so a subset can be rotated
	// rigidly about the puzzle centroid just by setting their .quaternion.
	const tiles = [];

	tetFaces.forEach(({ idx }, faceIndex) => {
		const [A, B, C] = orientOutward(tetVerts[idx[0]], tetVerts[idx[1]], tetVerts[idx[2]]);
		const faceNormal = new THREE.Vector3()
			.subVectors(B, A)
			.cross(new THREE.Vector3().subVectors(C, A))
			.normalize();

		// planar UV basis on the face, so the pattern is continuous across its tiles
		const uAxis = new THREE.Vector3().subVectors(B, A).normalize();
		const vAxis = new THREE.Vector3().crossVectors(faceNormal, uAxis).normalize();
		const uvOf = (p) => {
			const d = new THREE.Vector3().subVectors(p, A);
			return [d.dot(uAxis) * UV_SCALE, d.dot(vAxis) * UV_SCALE];
		};

		// barycentric grid point: ((N-i-j)A + iB + jC) / N
		const point = (i, j) =>
			new THREE.Vector3()
				.addScaledVector(A, (SUBDIV - i - j) / SUBDIV)
				.addScaledVector(B, i / SUBDIV)
				.addScaledVector(C, j / SUBDIV);

		const tris = [];
		for (let i = 0; i < SUBDIV; i++) {
			for (let j = 0; j < SUBDIV - i; j++) {
				tris.push([point(i, j), point(i + 1, j), point(i, j + 1)]); // upward
				if (i + j < SUBDIV - 1) {
					tris.push([point(i + 1, j), point(i + 1, j + 1), point(i, j + 1)]); // downward
				}
			}
		}

		const tileMaterial = faceMaterials[faceIndex];

		const quad = (p0, p1, p2, p3) => [...triPositions(p0, p1, p2), ...triPositions(p0, p2, p3)];

		tris.forEach((tri) => {
			const center = new THREE.Vector3()
				.add(tri[0])
				.add(tri[1])
				.add(tri[2])
				.multiplyScalar(1 / 3);
			// colored top face (lifted slightly off the tetra surface)
			const top = tri.map((p) =>
				new THREE.Vector3()
					.lerpVectors(center, p, TILE_SHRINK)
					.addScaledVector(faceNormal, TILE_LIFT),
			);
			const cV = new THREE.Vector3().add(top[0]).add(top[1]).add(top[2]).multiplyScalar(1 / 3);
			// bevel ring: pulled slightly inward and down -> softens the top edge
			const bevel = top.map((p) =>
				new THREE.Vector3()
					.lerpVectors(p, cV, TILE_BEVEL_INSET)
					.addScaledVector(faceNormal, -TILE_BEVEL_DEPTH),
			);
			// back ring: bevel pulled toward the centroid (origin) so the chip is a
			// wedge reaching deep into the body -> the pieces fill the volume with no
			// hollow gap, and the inner overlap stays hidden inside the dark core
			const back = bevel.map((p) => p.clone().multiplyScalar(TILE_BACK_SCALE));

			const frontGeo = new THREE.BufferGeometry();
			frontGeo.setAttribute('position', new THREE.Float32BufferAttribute(triPositions(top[0], top[1], top[2]), 3));
			frontGeo.setAttribute(
				'uv',
				new THREE.Float32BufferAttribute([...uvOf(top[0]), ...uvOf(top[1]), ...uvOf(top[2])], 2),
			);
			frontGeo.computeVertexNormals();

			// shell = bevel strip + side walls + back (DoubleSide, so winding is moot)
			const shellPos = [...triPositions(back[0], back[2], back[1])];
			for (let e = 0; e < 3; e++) {
				const n = (e + 1) % 3;
				shellPos.push(...quad(top[e], top[n], bevel[n], bevel[e])); // rounded edge strip
				shellPos.push(...quad(bevel[e], bevel[n], back[n], back[e])); // side wall
			}
			const shellGeo = new THREE.BufferGeometry();
			shellGeo.setAttribute('position', new THREE.Float32BufferAttribute(shellPos, 3));
			shellGeo.computeVertexNormals();

			const chip = new THREE.Group();
			const frontMesh = new THREE.Mesh(frontGeo, tileMaterial);
			const shellMesh = new THREE.Mesh(shellGeo, shellMaterial);
			// opaque pieces never need culling; disabling it rules out the chips
			// popping out of view at certain rotations
			frontMesh.frustumCulled = false;
			shellMesh.frustumCulled = false;
			chip.add(frontMesh, shellMesh);
			pyramidGroup.add(chip);

			tiles.push({ mesh: chip, centroid: cV.clone(), baseQ: new THREE.Quaternion() });
		});
	});

	const ambientLight = new THREE.AmbientLight(0x4a4a5a, 0.5);
	scene.add(ambientLight);

	const mainLight = new THREE.PointLight(0xaaaaaa, 1.5, 100);
	mainLight.position.set(2, 5, 3);
	scene.add(mainLight);

	const topLight = new THREE.PointLight(0xbbbbbb, 1.0, 100);
	topLight.position.set(1, 1, 1);
	scene.add(topLight);

	const accentLight1 = new THREE.PointLight(0x00FF7F, 1.0, 50);
	accentLight1.position.set(-5, -5, 5);
	scene.add(accentLight1);

	const accentLight2 = new THREE.PointLight(0x9A1AFF, 1.0, 50);
	accentLight2.position.set(5, -5, -5);
	scene.add(accentLight2);

	const accentLight3 = new THREE.PointLight(0x6E6EFF, 1.0, 50);
	accentLight3.position.set(-5, 5, -5);
	scene.add(accentLight3);

	const rimLight1 = new THREE.DirectionalLight(0xffffff, 0.1);
	rimLight1.position.set(0, -5, 5);
	scene.add(rimLight1);

	const rimLight2 = new THREE.DirectionalLight(0xffffff, 0.6);
	rimLight2.position.set(0, -5, -5);
	scene.add(rimLight2);

	const blurLight1 = new THREE.PointLight(0x00FF7F, 0.6, 30);
	blurLight1.position.set(3, 3, 3);
	scene.add(blurLight1);

	const blurLight2 = new THREE.PointLight(0x9A1AFF, 0.6, 30);
	blurLight2.position.set(-3, -3, 3);
	scene.add(blurLight2);

	// bright orbiting specular lights: their highlights sweep across the faces
	// and trace the roughness patterns, making each material distinguishable
	const orbitLightA = new THREE.PointLight(0xffffff, 2.4, 40);
	scene.add(orbitLightA);
	const orbitLightB = new THREE.PointLight(0xeaf0ff, 2.0, 40);
	scene.add(orbitLightB);

	const fluidMaterial = new THREE.MeshPhysicalMaterial({
		color: accentColor.clone().lerp(highlightColor, 0.5),
		metalness: 0.2,
		roughness: 0.05,
		clearcoat: 1,
		clearcoatRoughness: 0.1,
		transmission: 0.85,
		thickness: 0.4,
		opacity: 0.9,
		transparent: true,
	});

	const fluidPath = new THREE.CatmullRomCurve3(
		[
			new THREE.Vector3(0, 1.2, 0.6),
			new THREE.Vector3(-0.2, 0.7, 0.4),
			new THREE.Vector3(-0.25, 0.2, 0.1),
			new THREE.Vector3(-0.15, -0.4, -0.1),
			new THREE.Vector3(0, -0.9, -0.2),
			new THREE.Vector3(0.15, -1.4, -0.15),
		],
		false,
		'spline',
	);

	const fluidTrail = new THREE.Mesh(
		new THREE.TubeGeometry(fluidPath, 80, 0.04, 12, false),
		fluidMaterial.clone(),
	);
	fluidTrail.material.opacity = 0.3;
	fluidTrail.material.transparent = true;
	scene.add(fluidTrail);

	const timeline = gsap.timeline({ repeat: -1 });
	timeline
		.to(
			ring.rotation,
			{
				z: '+=6.28319',
				x: '+=6.28319',
				duration: 18,
				ease: 'power1.inOut',
			},
			0,
		)
		.to(
			group.rotation,
			{
				y: 6.28319,
				duration: 18,
				ease: 'power1.inOut',
			},
			0,
		)
		.to(
			pyramidGroup.rotation,
			{
				z: '-=6.28319',
				x: '-=6.28319',
				duration: 18,
				ease: 'power1.inOut',
			},
			0,
		);

	// Rubik's Pyramid moves: a move rotates HALF the puzzle (the 4 pieces on one
	// side of the centroid: 2 corner pieces + 2 center pieces) by 180deg about an
	// opposite-edge-midpoint axis. That axis-rotation is a symmetry of the regular
	// tetrahedron, so the puzzle bulges into a star at the 90deg midpoint and then
	// re-forms a tetrahedron, exactly the shape-shift shown in the solution guide.
	const HALF_TURN = Math.PI;
	const moveAxisV = new THREE.Vector3();
	const moveDeltaQ = new THREE.Quaternion();
	const moveTmpV = new THREE.Vector3();

	// each move is the pair of vertices that make up the rotating half
	const moveSequence = [
		[0, 1],
		[0, 2],
		[1, 3],
		[0, 3],
		[1, 2],
	];

	const addMove = (tl, pair, position) => {
		const axis = new THREE.Vector3()
			.addVectors(tetVerts[pair[0]], tetVerts[pair[1]])
			.normalize();
		const proxy = { a: 0 };
		let movers = [];
		tl.to(
			proxy,
			{
				a: HALF_TURN,
				duration: 2.8,
				ease: 'power2.inOut',
				onStart: () => {
					// pick the tiles currently on the rotating side, using their live
					// (already-rotated) centroid so moves compose like a real puzzle
					movers = tiles.filter((t) => {
						moveTmpV.copy(t.centroid).applyQuaternion(t.mesh.quaternion);
						return moveTmpV.dot(axis) > 0.02;
					});
					movers.forEach((t) => t.baseQ.copy(t.mesh.quaternion));
				},
				onUpdate: () => {
					moveDeltaQ.setFromAxisAngle(moveAxisV.copy(axis), proxy.a);
					movers.forEach((t) => t.mesh.quaternion.copy(moveDeltaQ).multiply(t.baseQ));
				},
			},
			position,
		);
	};

	const moveTimeline = gsap.timeline({ repeat: -1, repeatDelay: 1.4, delay: 1.5 });
	moveSequence.forEach((pair, i) => {
		addMove(moveTimeline, pair, i === 0 ? 0 : '+=1.1'); // pause between moves
	});

	let mouseX = 0;
	let mouseY = 0;
	let targetRotationX = 0;
	let targetRotationY = 0;
	let currentRotationX = 0;
	let currentRotationY = 0;

	window.addEventListener('mousemove', (e) => {
		const rect = canvas.getBoundingClientRect();
		mouseX = (e.clientX - rect.left) / canvas.clientWidth;
		mouseY = (e.clientY - rect.top) / canvas.clientHeight;

		mainLight.position.x = (mouseX - 0.5) * 10;
		mainLight.position.z = (mouseY - 0.5) * 10;

		topLight.position.x = -mouseX * 10;
		topLight.position.z = -mouseY * 10;

		blurLight1.position.x = (mouseX - 0.5) * 6;
		blurLight1.position.z = (mouseY - 0.5) * 6;
		blurLight2.position.x = -(mouseX - 0.5) * 6;
		blurLight2.position.z = -(mouseY - 0.5) * 6;

		targetRotationX = (mouseY - 0.5) * 0.5;
		targetRotationY = (mouseX - 0.5) * 0.5;
	});

	const handleResize = () => {
		const width = canvas.clientWidth;
		const height = canvas.clientHeight;

		renderer.setSize(width, height);
		camera.aspect = width / height;
		camera.updateProjectionMatrix();

		if (width > height) {
			camera.position.z = 5;
		} else {
			camera.position.z = 7;
		}
	};

	window.addEventListener('resize', handleResize);
	handleResize();

	function animate() {
		requestAnimationFrame(animate);

		currentRotationX += (targetRotationX - currentRotationX) * 0.05;
		currentRotationY += (targetRotationY - currentRotationY) * 0.05;

		pyramidGroup.rotation.x = currentRotationX;
		pyramidGroup.rotation.y = currentRotationY;

		const time = Date.now() * 0.001;
		blurLight1.position.y = 2 + Math.sin(time) * 0.02;
		blurLight2.position.y = -2 + Math.cos(time) * 0.02;

		orbitLightA.position.set(Math.cos(time * 0.8) * 4.5, Math.sin(time * 1.05) * 3.5, Math.sin(time * 0.8) * 4.5);
		orbitLightB.position.set(Math.cos(time * 0.55 + 2.1) * -4.5, Math.cos(time * 0.7) * 3.0, Math.sin(time * 0.55 + 2.1) * -4.5);

		const offsetSpeed = 0.02;
		metalTexture.offset.x = THREE.MathUtils.damp(metalTexture.offset.x, (metalTexture.offset.x + offsetSpeed * 0.01) % 1, 6, 0.016);
		metalTexture.offset.y = THREE.MathUtils.damp(metalTexture.offset.y, (metalTexture.offset.y + offsetSpeed * 0.006) % 1, 6, 0.016);
		metalTexture.needsUpdate = true;

		const pyramidHue = (time * 0.05) % 1;

		const paletteMixA = (Math.sin(time * 0.12) + 1) * 0.5;
		const paletteMixB = (Math.cos(time * 0.1) + 1) * 0.5;
		blendColor
			.copy(accentColor)
			.lerp(highlightColor, paletteMixA)
			.lerp(secondaryColor, paletteMixB * 0.6)
			.offsetHSL((pyramidHue - 0.5) * 0.2, 0, 0);
		emissiveColor.copy(blendColor).lerp(highlightColor, 0.5);
		// keep the ring as dark chrome (like the faces): just a faint shifting tint + glow
		material.color.copy(darkColor).lerp(blendColor, 0.16);
		material.emissive.copy(emissiveColor).multiplyScalar(0.12);

		renderer.render(scene, camera);
	}

	animate();
</script>
